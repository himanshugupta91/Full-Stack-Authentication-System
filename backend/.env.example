# Copy to backend/.env and fill in real values before running.

# Core runtime
SERVER_PORT=8080
APP_FRONTEND_URL=http://localhost:5173
APP_BACKEND_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://authsystem-plum.vercel.app

# Database and Redis
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/auth_db
SPRING_DATASOURCE_USERNAME=auth_user
SPRING_DATASOURCE_PASSWORD=change-this-db-password
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Docker-only backend connectivity overrides (optional)
# Use container service names when running the app service in docker compose.
DOCKER_SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/auth_db
DOCKER_SPRING_DATASOURCE_USERNAME=auth_user
DOCKER_SPRING_DATA_REDIS_HOST=redis
DOCKER_SPRING_DATA_REDIS_PORT=6379

# JWT and token hashing (required)
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-64-byte-random-secret
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
# Optional override (defaults to JWT_SECRET when omitted)
SECURITY_TOKEN_HASH_PEPPER=

# SMTP (required for OTP/reset email delivery)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@example.com
SPRING_MAIL_PASSWORD=your-app-password

# OAuth2 provider credentials (set real values only for providers you enable)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=

# Refresh-token cookie behavior
# Set true in production HTTPS deployments.
AUTH_REFRESH_TOKEN_COOKIE_SECURE=false
AUTH_REFRESH_TOKEN_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_TOKEN_COOKIE_DOMAIN=

# Optional seeded admin (disabled by default)
APP_SEED_ADMIN_ENABLED=false
APP_SEED_ADMIN_NAME=
APP_SEED_ADMIN_EMAIL=
APP_SEED_ADMIN_PASSWORD=
